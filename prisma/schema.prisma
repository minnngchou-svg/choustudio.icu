// Prisma Schema for 设计师个人网站
// 数据库: 开发可用 PostgreSQL (Neon) 或 MySQL；生产部署推荐 MySQL（如阿里云服务器）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户模型 ====================
enum Role {
  ADMIN   // 管理员：完整读写权限
  VIEWER  // 体验账户：仅可浏览后台，无法修改
  USER    // 前台注册用户
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  role          Role     @default(USER)
  name          String?  @db.VarChar(100)
  avatar        String?  @db.Text
  bio           String?  @db.Text
  nickname      String?  @db.VarChar(50)
  memberLevel   Int      @default(0)
  favorites     Json?
  preferences   Json?
  disabled      Boolean  @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  posts         Post[]
  works         Work[]
  orders        Order[]
  accountOrders AccountOrder[]
  history       BrowsingHistory[]
}

// ==================== 浏览历史模型 ====================
model BrowsingHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemType   String   @db.VarChar(20)
  itemId     String   @db.VarChar(64)
  title      String   @db.VarChar(255)
  coverImage String?  @db.Text
  createdAt  DateTime @default(now())

  @@unique([userId, itemType, itemId])
  @@index([userId])
  @@index([userId, createdAt])
}

// ==================== 文章模型 ====================
model Post {
  id          String     @id @default(cuid())
  title       String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  content     Json
  excerpt     String?    @db.Text
  coverImage  String?    @db.Text
  coverRatio  String     @default("3:4") @db.VarChar(10)
  status      PostStatus @default(DRAFT)
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  tags        Tag[]
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?

  @@index([status])
  @@index([categoryId])
  @@index([authorId])
}

// ==================== 作品模型 ====================
enum WorkType {
  DESIGN
  DEVELOPMENT
}

model Work {
  id             String        @id @default(cuid())
  title          String        @db.VarChar(255)
  slug           String        @unique @db.VarChar(255)
  workType       WorkType      @default(DESIGN)
  description    String?       @db.Text
  content        Json?
  coverImage     String        @db.Text
  coverRatio     String        @default("3:4") @db.VarChar(10)
  images         Json
  currentVersion String?       @db.VarChar(20)
  price          Decimal?      @db.Decimal(10, 2)
  isFree         Boolean       @default(false)
  figmaUrl       String?       @db.Text
  deliveryUrl    String?       @db.Text
  fileUrl        String?       @db.Text
  fileName       String?       @db.VarChar(255)
  demoUrl        String?       @db.Text
  demoQrCode     String?       @db.Text
  status         WorkStatus    @default(DRAFT)
  categoryId     String?
  category       Category?     @relation(fields: [categoryId], references: [id])
  authorId       String
  author         User          @relation(fields: [authorId], references: [id])
  tags           Tag[]
  orders         Order[]
  versions       WorkVersion[]
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([workType])
  @@index([categoryId])
  @@index([authorId])
}

// ==================== 作品版本模型 ====================
model WorkVersion {
  id          String   @id @default(cuid())
  workId      String
  work        Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  version     String   @db.VarChar(20)
  price       Decimal  @db.Decimal(10, 2)
  changelog   String?  @db.Text
  figmaUrl    String?  @db.Text
  deliveryUrl String?  @db.Text
  fileUrl     String?  @db.Text
  fileName    String?  @db.VarChar(255)
  createdAt   DateTime @default(now())

  orders Order[]

  @@unique([workId, version])
  @@index([workId])
}

// ==================== 订单模型 ====================
model Order {
  id            String       @id @default(cuid())
  orderNo       String       @unique @db.VarChar(64)
  workId        String
  work          Work         @relation(fields: [workId], references: [id])
  versionId     String?
  version       WorkVersion? @relation(fields: [versionId], references: [id])
  upgradeFromId String?      @db.VarChar(64)
  amount        Decimal      @db.Decimal(10, 2)
  status        OrderStatus  @default(PENDING)
  buyerEmail    String       @db.VarChar(255)
  buyerName     String?      @db.VarChar(100)
  paymentId     String?      @db.VarChar(64)
  paidAt        DateTime?
  downloadToken String?      @unique @db.VarChar(64)
  downloadCount Int          @default(0)
  executed      Boolean      @default(false)
  executedAt    DateTime?
  userId        String?
  user          User?        @relation(fields: [userId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([workId])
  @@index([versionId])
  @@index([buyerEmail])
  @@index([userId])
}

// ==================== 分类模型 ====================
model Category {
  id              String           @id @default(cuid())
  name            String           @db.VarChar(100)
  slug            String           @unique @db.VarChar(100)
  type            CategoryType
  posts           Post[]
  works           Work[]
  tutorials       VideoTutorial[]
  accountProducts AccountProduct[]
}

// ==================== 标签模型 ====================
model Tag {
  id              String           @id @default(cuid())
  name            String           @unique @db.VarChar(50)
  posts           Post[]
  works           Work[]
  tutorials       VideoTutorial[]
  accountProducts AccountProduct[]
}

// ==================== 媒体文件模型 ====================
model Media {
  id         String   @id @default(cuid())
  name       String   @db.VarChar(255)
  url        String   @db.Text
  type       String   @db.VarChar(50)
  size       Int
  width      Int?
  height     Int?
  entityType String   @db.VarChar(50)
  entityId   String   @db.VarChar(64)
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([entityType])
  @@index([entityType, entityId])
}

// ==================== 网站设置模型 ====================
model Settings {
  id          String  @id @default("settings")
  siteName    String  @default("Chou's Studio") @db.VarChar(255)
  avatar      String? @db.Text
  socialLinks Json?
  about       Json?
  nav         Json?
  pageCopy    Json?
  theme       Json?
  footer      Json?
  updatedAt   DateTime @updatedAt
}

// ==================== 视频教程模型 ====================
model VideoTutorial {
  id          String    @id @default(cuid())
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?   @db.Text
  videoUrl    String    @db.Text
  thumbnail   String?   @db.Text
  coverRatio  String    @default("3:4") @db.VarChar(10)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        Tag[]
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([categoryId])
}

// ==================== AI 服务 / 账号商品模型 ====================
model AccountProduct {
  id             String               @id @default(cuid())
  title          String               @db.VarChar(255)
  slug           String               @unique @db.VarChar(255)
  description    String?              @db.Text
  content        Json?
  coverImage     String?              @db.Text
  coverRatio     String               @default("3:4") @db.VarChar(10)
  accountType    String               @db.VarChar(50)
  price          Decimal              @db.Decimal(10, 2)
  originalPrice  Decimal?             @db.Decimal(10, 2)
  stock          Int                  @default(0)
  validDays      Int?
  features       Json?
  securityNote   String?              @db.Text
  transferGuide  String?              @db.Text
  warranty       String?              @db.Text
  status         AccountProductStatus @default(DRAFT)
  categoryId     String?
  category       Category?            @relation(fields: [categoryId], references: [id])
  tags           Tag[]
  orders         AccountOrder[]
  sortOrder      Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([status])
  @@index([accountType])
  @@index([categoryId])
}

// ==================== 账号商品订单模型 ====================
model AccountOrder {
  id               String         @id @default(cuid())
  orderNo          String         @unique @db.VarChar(64)
  accountProductId String
  accountProduct   AccountProduct @relation(fields: [accountProductId], references: [id])
  amount           Decimal        @db.Decimal(10, 2)
  status           OrderStatus    @default(PENDING)
  buyerEmail       String         @db.VarChar(255)
  buyerName        String?        @db.VarChar(100)
  deliveryInfo     Json?
  deliveredAt      DateTime?
  paidAt           DateTime?
  executed         Boolean        @default(false)
  executedAt       DateTime?
  userId           String?
  user             User?          @relation(fields: [userId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([status])
  @@index([accountProductId])
  @@index([buyerEmail])
  @@index([userId])
}

// ==================== 枚举类型 ====================
enum PostStatus {
  DRAFT
  PUBLISHED
  PRIVATE
}

enum WorkStatus {
  DRAFT
  PUBLISHED
  PRIVATE
}

enum AccountProductStatus {
  DRAFT
  PUBLISHED
  PRIVATE
  SOLD_OUT
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDING
  REFUNDED
}

enum CategoryType {
  POST
  WORK
  DESIGN
  DEVELOPMENT
  TUTORIAL
  ACCOUNT
}
